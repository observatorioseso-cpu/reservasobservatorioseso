# ============================================================
# Production Environment Variables — reservasobservatorioseso.cl
# ============================================================
# Copy this file to .env.production.local and fill in the values.
# NEVER commit .env.production.local or any file containing real secrets.
# All secrets should be set via the Vercel dashboard or `vercel env add`.
# ============================================================

# ------------------------------------------------------------
# Node environment
# Set automatically by Vercel; include here for local reference.
# ------------------------------------------------------------
NODE_ENV=production

# ------------------------------------------------------------
# Database — PostgreSQL via Prisma
# Use the connection pooler URL for serverless (Neon or Supabase).
# Neon format:    postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Supabase format: postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# ------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# ------------------------------------------------------------
# Application base URL
# Must include the protocol and no trailing slash.
# Used for generating absolute links in emails and PDFs.
# ------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://reservasobservatorioseso.cl

# ------------------------------------------------------------
# Admin authentication
# 64-character hex string (256 bits) used for HMAC-SHA256 admin token signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Protects /admin, /api/admin/*, and /api/export endpoints.
# ------------------------------------------------------------
ADMIN_SECRET_KEY=your_64_character_hex_string_here

# ------------------------------------------------------------
# Anthropic Claude API
# Required for Agent 1 (reservation validator, claude-haiku-4-5)
# and Agent 5 (chat assistant, claude-sonnet-4-6 with prompt caching).
# Agents 2, 3, and 4 are LLM-free and do not use this key.
# Get your key at: https://console.anthropic.com/api-keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ------------------------------------------------------------
# Resend — Transactional email
# Used for confirmation, modification, cancellation, and reminder emails.
# The domain (reservasobservatorioseso.cl) must be verified in Resend.
# Get your key at: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@reservasobservatorioseso.cl

# ------------------------------------------------------------
# Twilio — WhatsApp notifications (optional)
# If these are not set, WhatsApp messages are silently skipped.
# The system continues to function fully without them.
# TWILIO_WHATSAPP_FROM format: whatsapp:+14155238886 (Twilio sandbox)
# or whatsapp:+YOUR_APPROVED_NUMBER (production)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ------------------------------------------------------------
# Upstash Redis — Chat widget rate limiting
# Used by Agent 5 to limit chat requests per IP per minute.
# If not set, rate limiting is skipped (fail-open) and chat still works.
# Create a database at: https://console.upstash.com
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ------------------------------------------------------------
# Vercel Cron authorization
# Secret sent in the Authorization header by Vercel Cron jobs.
# Must match what the cron handlers check: Authorization: Bearer [CRON_SECRET]
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ------------------------------------------------------------
CRON_SECRET=your_32_character_hex_cron_secret_here
