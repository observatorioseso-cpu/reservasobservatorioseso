# ============================================================
# Entorno LOCAL de desarrollo — reservasobservatorioseso.cl
# ============================================================
# Copia este archivo como .env.local y completa los valores.
# .env.local está en .gitignore — nunca se sube al repositorio.
#
# REQUISITO: Para ejecutar `npm run dev` o `npm run build`
# localmente necesitas DATABASE_URL apuntando a una BD real
# o a Docker con PostgreSQL.
# ============================================================

# Base de datos local (ejemplo con Docker)
# docker run -d -e POSTGRES_DB=eso_dev -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:dev@localhost:5432/eso_dev

# URL base local
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Clave admin — genera una nueva:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET_KEY=dev_reemplaza_con_64_chars_hex_aleatorios_aqui_000000000000000000

# Anthropic (puedes usar tu propia API key de desarrollo)
ANTHROPIC_API_KEY=sk-ant-tu_api_key_aqui

# Resend (en desarrollo puedes omitirlo — emails no se enviarán)
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=noreply@reservasobservatorioseso.cl

# Twilio WhatsApp (opcional — omitir en local)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# Upstash Redis (opcional — sin esto el rate limiting falla-abierto)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Cron secret (en desarrollo puedes usar cualquier string)
CRON_SECRET=dev_cron_secret_local

# Sentry (opcional en local — omitir si no tienes proyecto Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/...
# SENTRY_DSN=https://...@o0.ingest.sentry.io/...
# SENTRY_ORG=tu-org-sentry
# SENTRY_PROJECT=reservasobservatorioseso
