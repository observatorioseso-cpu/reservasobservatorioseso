# ─────────────────────────────────────────────
# Base de datos (PostgreSQL via Supabase o Railway)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:5432/eso_reservas"
# Para Supabase: usar puerto 6543 (PgBouncer) en producción
# DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"

# ─────────────────────────────────────────────
# Auth (NextAuth)
# ─────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="https://reservasobservatorioseso.cl"

# ─────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@reservasobservatorioseso.cl"
EMAIL_RESERVAS="reservas@observatorioseso.cl"
# Emails del equipo admin para reportes semanales/mensuales
ADMIN_EMAILS="admin@observatorioseso.cl,equipo@observatorioseso.cl"

# ─────────────────────────────────────────────
# WhatsApp (Meta Business Cloud API)
# ─────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_BUSINESS_ACCOUNT_ID="987654321"
WHATSAPP_VERIFY_TOKEN="CHANGE_ME_secreto_verificacion"

# ─────────────────────────────────────────────
# Anthropic (Agentes IA)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxxxxxx"

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
# Generar con: openssl rand -hex 32
ADMIN_TOKEN="CHANGE_ME"

# ─────────────────────────────────────────────
# Rate limiting (Upstash Redis)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxY"

# ─────────────────────────────────────────────
# Sentry (monitoreo de errores)
# ─────────────────────────────────────────────
SENTRY_DSN="https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxx"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://reservasobservatorioseso.cl"
TZ="America/Santiago"
